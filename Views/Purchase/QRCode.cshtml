@model FlightManagementWeb.Models.Purchase

@{
    ViewData["QRCode"] = "QRCode";
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h2>Boarding Pass QR Code</h2>
            
            <div class="card mt-4">
                <div class="card-body">
                    <h5 class="card-title">Booking Number: @ViewBag.PurchaseNumber</h5>
                    
                    <div class="mt-4">
                        <img src="data:image/png;base64,@ViewBag.QRCodeImage" 
                             alt="QR Code" 
                             class="img-fluid" 
                             style="max-width: 300px;">
                    </div>
                    
                    <p class="mt-3 text-muted">Scan this QR code at check-in</p>
                </div>
            </div>
            
            <a asp-action="Profile" asp-controller="Profile" class="btn btn-secondary mt-3">
                Back to Profile
            </a>
        </div>
    </div>
</div>