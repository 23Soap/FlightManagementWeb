@model FlightManagementWeb.Models.Flight

@{
    ViewData["DeleteFlight"] = "DeleteFlight";
}


<body>
<form method="post" asp-action="DeleteFlight">
    
    <input type="hidden" as/>

    <p class="text-danger">Flight INFO:</p>
    <P class="text-danger">Aircraft Tail Number:@Model.Aircraft.TailNumber . From @Model.DepartureCity TO @Model.ArrivalCity</P>
    <h3>Are you Sure you want to delete this?</h3>
    <button asp-action="DeleteFlight" asp-route-id="@Model.FlightId" class="btn btn-danger">Yes</button>
    <a asp-action="Admin" asp-route-id="@Model.FlightId" class="btn btn-primary">No</a>
</form>
<div>
    
</div>
</body>
