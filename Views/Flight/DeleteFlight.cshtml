@model Flight

@{
    ViewData["DeleteFlight"] = "DeleteFlight";
}

<!DOCTYPE html>

<html>
<head>
    <h2>Delete</h2>
   
</head>
<body>
<form method="post" asp-action="DeleteFlight">
    
    <p class="text-danger">@ViewData["ErrorMessage"]</p>
    <h3>Are you Sure you want to delete this?</h3>
    <button asp-action="DeleteFlight" asp-route-id="@Model.FlightId" class="btn btn-danger">Yes</button>
    <a asp-action="EditFlight" asp-route-id="@Model.FlightId" class="btn btn-primary">No</a>
</form>
<div>
    
</div>
</body>
</html>