@model FlightManagementWeb.Models.Flight

@{
    ViewData["BuyFlight"] = "Buy Flight";
}

<form asp-action="BuyFlight" asp-controller="Flight" asp-route-id="@Model.FlightId" method="post">
    <div style="max-width: 560px; margin: 2rem auto; padding: 0 1rem;">

    <p style="font-size: 13px; color: #6b7280; margin: 0 0 4px;">Step 2 of 2</p>
    <h2 style="font-size: 20px; font-weight: 500; margin: 0 0 1.5rem;">Confirm your booking</h2>

    <div class="card mb-3">
        <div class="card-body border-bottom pb-3 d-flex justify-content-between align-items-center">
            <div class="text-center">
                <p class="text-muted small mb-1">From</p>
                <p class="fs-4 fw-semibold mb-0">@Model.DepartureCity</p>
            </div>
            <div class="text-muted">→</div>
            <div class="text-center">
                <p class="text-muted small mb-1">To</p>
                <p class="fs-4 fw-semibold mb-0">@Model.ArrivalCity</p>
            </div>
        </div>

        <div class="card-body border-bottom">
            <div class="row g-3">
                <div class="col-6">
                    <p class="text-muted small mb-1">Airline</p>
                    <p class="fw-medium mb-0">@Model.Aircraft.AirlineName</p>
                </div>
                <div class="col-6">
                    <p class="text-muted small mb-1">Aircraft</p>
                    <p class="fw-medium mb-0">@Model.Aircraft.AircraftModel</p>
                </div>
                <div class="col-6">
                    <p class="text-muted small mb-1">Tail Number</p>
                    <p class="fw-medium mb-0">@Model.Aircraft.TailNumber</p>
                </div>
                <div class="col-6">
                    <p class="text-muted small mb-1">Departure</p>
                    <p class="fw-medium mb-0">@Model.DepartureDate.ToString("MMM dd, yyyy HH:mm")</p>
                </div>
            </div>
        </div>

        <div class="card-body d-flex justify-content-between align-items-center">
            <p class="text-muted mb-0">Total price</p>
            <p class="fs-3 fw-semibold text-primary mb-0">$@Model.Price</p>
        </div>
    </div>

    <form asp-action="BuyFlight" asp-controller="Flight" asp-route-id="@Model.FlightId" method="post">
        <div class="d-flex gap-3">
            <a asp-action="SearchMenu" asp-controller="Flight" class="btn btn-outline-secondary flex-fill">Go back</a>
            <button type="submit" class="btn btn-primary flex-fill">Confirm purchase</button>
        </div>
    </form>

</div>
</form>


