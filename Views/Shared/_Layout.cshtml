<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - FlightManagementWeb</title>
    <script type="importmap"></script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            prefix: 'tw-',
            corePlugins: {
                preflight: false,
            }
        }
    </script>
    
    <style>
    :root {
        --color-brand: #1d4ed8;
        --color-brand-strong: #1e40af;
        --color-brand-medium: #93c5fd;
        --color-brand-soft: #dbeafe;
        --color-neutral-primary-medium: #ffffff;
        --color-neutral-secondary-medium: #f9fafb;
        --color-neutral-tertiary-medium: #f3f4f6;
        --color-neutral-quaternary: #d1d5db;
        --color-default-medium: #e5e7eb;
        --color-heading: #111827;
        --color-body: #6b7280;
        --color-fg-brand: #1d4ed8;
        --color-buffer: #ffffff;
        --color-danger: #dc2626;
        --color-danger-strong: #b91c1c;
        --color-danger-medium: #fca5a5;
    }

    /* Background classes */
    .bg-brand { background-color: var(--color-brand) !important; }
    .bg-brand-strong { background-color: var(--color-brand-strong) !important; }
    .bg-brand-soft { background-color: var(--color-brand-soft) !important; }
    .bg-neutral-primary-medium { background-color: var(--color-neutral-primary-medium) !important; }
    .bg-neutral-secondary-medium { background-color: var(--color-neutral-secondary-medium) !important; }
    .bg-neutral-tertiary-medium { background-color: var(--color-neutral-tertiary-medium) !important; }
    .bg-neutral-quaternary { background-color: var(--color-neutral-quaternary) !important; }
    .bg-danger { background-color: var(--color-danger) !important; }
    .bg-danger-strong { background-color: var(--color-danger-strong) !important; }

    /* Text classes */
    .text-heading { color: var(--color-heading) !important; }
    .text-body { color: var(--color-body) !important; }
    .text-fg-brand { color: var(--color-fg-brand) !important; }

    /* Border classes */
    .border-default-medium { border-color: var(--color-default-medium) !important; }
    .border-brand { border-color: var(--color-brand) !important; }

    /* Hover classes */
    .hover\:bg-brand-strong:hover { background-color: var(--color-brand-strong) !important; }
    .hover\:bg-neutral-tertiary-medium:hover { background-color: var(--color-neutral-tertiary-medium) !important; }
    .hover\:text-heading:hover { color: var(--color-heading) !important; }

    /* Focus classes */
    .focus\:ring-brand:focus { --tw-ring-color: var(--color-brand) !important; }
    .focus\:ring-brand-medium:focus { --tw-ring-color: var(--color-brand-medium) !important; }
    .focus\:border-brand:focus { border-color: var(--color-brand) !important; }

    /* Misc */
    .rounded-base { border-radius: 0.5rem !important; }
    .shadow-xs { box-shadow: 0 1px 2px rgba(0,0,0,0.05) !important; }
    .leading-5 { line-height: 1.25rem !important; }
</style>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/FlightManagementWeb.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">FlightManagementWeb</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Search" asp-action="SearchMenu">Menu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Flight" asp-action="Admin">Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Aircraft" asp-action="AircraftMenu">Aircraft Menu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                    <li>
                        <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li>
                        <a class="nav-link text-dark" asp-controller="Profile" asp-action="Profile">Profile</a>
                    </li>
                    <li>
                        <form method="post" asp-controller="Account" asp-action="Logout">
                            <button type="submit" class="nav-link text-dark" asp-controller="Account" asp-action="LogOut" method="post">Logout</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - FlightManagementWeb - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<!-- ✅ Flowbite v2 JS only, at the bottom -->
<script src="https://cdn.jsdelivr.net/npm/flowbite@2.3.0/dist/flowbite.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>