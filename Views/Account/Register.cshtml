@model FlightManagementWeb.Models.Register

@{
    ViewData["Title"] = "Register";
}

<form asp-action="Register" asp-controller="Account" method="post">
    <h1 class="h3 mb-3 fw-normal">Create account</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div class="alert alert-danger py-2">@error.ErrorMessage</div>
        }
    }

    <div class="form-floating">
        <input asp-for="FirstName" type="text" class="form-control" placeholder="John"/>
        <label asp-for="FirstName">First Name</label>
    </div>

    <div class="form-floating">
        <input asp-for="LastName" type="text" class="form-control" placeholder="Doe"/>
        <label asp-for="LastName">Last Name</label>
    </div>

    <div class="form-floating">
        <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com"/>
        <label asp-for="Email">Email</label>
    </div>

    <div class="form-floating">
        <input asp-for="Password" type="password" class="form-control" placeholder="Password"/>
        <label asp-for="Password">Password</label>
    </div>

    <div class="form-floating">
        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password"/>
        <label asp-for="ConfirmPassword">Confirm Password</label>
    </div>

    <div class="form-floating">
        <input asp-for="DateOfBirth" type="date" class="form-control"/>
        <label asp-for="DateOfBirth">Date of Birth</label>
    </div>

    <button type="submit" class="btn btn-primary w-100 py-2 mt-3">Register</button>

    <p class="mt-4 text-center text-body-secondary">
        Already have an account? 
        <a asp-controller="Account" asp-action="Login">Sign in</a>
    </p>
</form>