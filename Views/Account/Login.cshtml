@model FlightManagementWeb.Models.Login

@{
    ViewData["Title"] = "Login";
}

<div class="d-flex align-items-center py-4 bg-body-tertiary" style="min-height: 100vh;">
    <main class="form-signin w-100 m-auto" style="max-width: 330px;">
        
        <form asp-action="Login" asp-controller="Account" method="post">
            
            <h1 class="h3 mb-3 fw-normal">Sign in</h1>

            @if (!ViewData.ModelState.IsValid)
            {
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="alert alert-danger py-2">@error.ErrorMessage</div>
                }
            }

            <div class="form-floating">
                <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com"/>
                <label asp-for="Email">Email address</label>
            </div>

            <div class="form-floating">
                <input asp-for="Password" type="password" class="form-control" placeholder="Password"/>
                <label asp-for="Password"></label>
            </div>

            <div class="form-check text-start my-3">
                <input asp-for="RememberMe" class="form-check-input" type="checkbox"/>
                <label class="form-check-label" asp-for="RememberMe">Remember me</label>
            </div>

            <button class="btn btn-primary w-100 py-2" type="submit">Sign in</button>

            <p class="mt-4 text-center text-body-secondary">Don't have an account? <a asp-controller="Account" asp-action="Register">Register</a></p>

        </form>
    </main>
</div>